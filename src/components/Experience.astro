---
import SectionHead from "./SectionHead.astro";
import { experience } from "../data/site";
---

<section id="experience" class="section">
  <div class="container-x">
    <SectionHead
      label={experience.label}
      heading={experience.heading}
      lead={experience.lead}
    />

    <div class="mt-12 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        experience.items.map((item) => (
          <article class="surface surface-hover p-6" data-reveal>
            <div class="grid h-11 w-11 place-items-center rounded-xl border border-line bg-card text-sm font-bold text-violet">
              {item.tag}
            </div>
            <h3 class="mt-5 text-lg font-semibold">{item.title}</h3>
            <p class="mt-3 text-sm text-muted">{item.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
