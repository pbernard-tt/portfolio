---
import SectionHead from "./SectionHead.astro";
import { systemHighlights } from "../data/site";
---

<section id="case-studies" class="section">
  <div class="container-x">
    <SectionHead
      label={systemHighlights.label}
      heading={systemHighlights.heading}
      lead={systemHighlights.lead}
    />

    <div class="mt-12 grid grid-cols-1 gap-6 lg:grid-cols-2">
      {
        systemHighlights.items.map((item, index) => (
          <article class="surface surface-hover flex h-full flex-col p-7" data-reveal>
            <div class="flex items-start gap-4">
              <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl border border-line bg-card text-sm font-bold text-violet">
                {String(index + 1).padStart(2, "0")}
              </span>
              <div>
                <h3 class="text-xl font-semibold">{item.title}</h3>
                <p class="mt-2 text-sm font-semibold text-muted">{item.summary}</p>
              </div>
            </div>

            <p class="mt-5 text-muted">{item.body}</p>

            <div class="mt-6 border-t border-line pt-5">
              <h4 class="text-xs font-bold uppercase tracking-widest text-muted">
                My focus
              </h4>
              <ul class="mt-3 grid gap-2 text-sm text-muted sm:grid-cols-2">
                {
                  item.focus.map((focus) => (
                    <li class="flex gap-2">
                      <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-violet" />
                      <span>{focus}</span>
                    </li>
                  ))
                }
              </ul>
            </div>

            <div class="mt-6 flex flex-wrap gap-2">
              {item.tags.map((tag) => <span class="chip">{tag}</span>)}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
