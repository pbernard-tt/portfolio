---
import { contact, site } from "../data/site";
---

<section id="contact" class="section">
  <div class="container-x">
    <div
      class="surface relative overflow-hidden p-8 sm:p-12"
      data-reveal
      style="background:
        linear-gradient(120deg, rgba(96,165,250,0.12), rgba(52,211,153,0.08) 60%, rgba(167,139,250,0.12)),
        var(--color-card);"
    >
      <div
        class="flex flex-col items-start justify-between gap-8 lg:flex-row lg:items-center"
      >
        <div class="max-w-2xl">
          <p class="label">{contact.label}</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">
            {contact.heading}
          </h2>
          <p class="mt-4 text-lg text-muted">{contact.body}</p>
        </div>
        <a href={contact.cta.href} class="btn btn-primary shrink-0">
          {contact.cta.label} →
        </a>
      </div>
    </div>

    <footer
      class="mt-10 flex flex-col gap-2 border-t border-line pt-8 text-sm text-muted sm:flex-row sm:items-center sm:justify-between"
    >
      <span>
        © {new Date().getFullYear()} {site.name}. Built around practical software,
        systems, and product execution.
      </span>
      <span>{site.location} • {site.availability}</span>
    </footer>
  </div>
</section>
