---
import { contact, site } from "../data/site";

const activeLinks = contact.links.filter((link) => Boolean(link.href));
---

<section id="contact" class="section">
  <div class="container-x">
    <div
      class="surface relative overflow-hidden p-8 sm:p-12"
      data-reveal
      style="background:
        linear-gradient(120deg, rgba(168,85,247,0.12), rgba(217,70,239,0.08) 60%, rgba(196,181,253,0.12)),
        var(--color-card);"
    >
      <div
        class="flex flex-col items-start justify-between gap-8 lg:flex-row lg:items-center"
      >
        <div class="max-w-2xl">
          <p class="label">{contact.label}</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">
            {contact.heading}
          </h2>
          <p class="mt-4 text-lg text-muted">{contact.body}</p>
          <div class="mt-5 flex flex-wrap gap-2 text-sm">
            <span class="chip">{site.role}</span>
            <span class="chip">{site.location}</span>
            <span class="chip">{site.domain}</span>
          </div>
        </div>
        <div class="flex shrink-0 flex-wrap gap-3">
          {
            activeLinks.map((link) => (
              <a
                href={link.href ?? "#"}
                class:list={[
                  "btn",
                  link.primary ? "btn-primary" : "btn-secondary",
                ]}
              >
                {link.label}
                {link.primary && <span aria-hidden="true">→</span>}
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <footer
      class="mt-10 flex flex-col gap-2 border-t border-line pt-8 text-sm text-muted sm:flex-row sm:items-center sm:justify-between"
    >
      <span>
        © {new Date().getFullYear()} {site.name}. Built around reliable software,
        systems, and product execution.
      </span>
      <span>{site.location} • {site.availability}</span>
    </footer>
  </div>
</section>
