---
interface Props {
  label: string;
  heading: string;
  lead?: string;
}
const { label, heading, lead } = Astro.props;
---

<div class="grid grid-cols-1 gap-6 lg:grid-cols-2 lg:items-end" data-reveal>
  <div>
    <p class="label">{label}</p>
    <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">
      {heading}
    </h2>
  </div>
  {lead && <p class="text-muted lg:pb-1">{lead}</p>}
</div>
