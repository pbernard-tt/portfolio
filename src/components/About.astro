---
import { about } from "../data/site";
---

<section id="about" class="section">
  <div class="container-x">
    <div class="surface relative overflow-hidden p-8 sm:p-12" data-reveal>
      <div
        class="pointer-events-none absolute right-0 top-0 -z-0 h-48 w-48 rounded-full bg-violet/10 blur-3xl"
        aria-hidden="true"
      >
      </div>
      <p class="label">{about.label}</p>
      <h2 class="mt-3 max-w-2xl text-3xl font-bold tracking-tight sm:text-4xl">
        {about.heading}
      </h2>
      <div class="mt-6 grid max-w-3xl gap-4 text-lg text-muted">
        {about.body.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </div>
</section>
