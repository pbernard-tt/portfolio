---
import { about } from "../data/site";
---

<section id="about" class="section">
  <div class="container-x">
    <div class="surface relative overflow-hidden p-8 sm:p-12" data-reveal>
      <div
        class="pointer-events-none absolute right-0 top-0 -z-0 h-48 w-48 rounded-full bg-violet/10 blur-3xl"
        aria-hidden="true"
      >
      </div>
      <p class="label">{about.label}</p>
      <h2 class="mt-3 max-w-2xl text-3xl font-bold tracking-tight sm:text-4xl">
        {about.heading}
      </h2>
      <div class="mt-6 grid max-w-3xl gap-4 text-lg text-muted">
        {about.body.map((p) => <p>{p}</p>)}
      </div>
      <div class="mt-9 border-t border-line pt-7">
        <h3 class="text-lg font-semibold text-text">
          {about.systemsThinking.title}
        </h3>
        <ol
          class="mt-4 flex flex-col gap-3 text-sm text-muted sm:flex-row sm:flex-wrap sm:items-center"
          aria-label={about.systemsThinking.title}
        >
          {
            about.systemsThinking.flow.map((step, index) => (
              <li class="flex items-center gap-3">
                <span class="chip">{step}</span>
                {index < about.systemsThinking.flow.length - 1 && (
                  <span class="hidden text-violet sm:inline" aria-hidden="true">
                    -&gt;
                  </span>
                )}
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </div>
</section>
