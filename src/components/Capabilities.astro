---
import SectionHead from "./SectionHead.astro";
import { strengths } from "../data/site";
---

<section id="strengths" class="section bg-bg-soft/40">
  <div class="container-x">
    <SectionHead
      label={strengths.label}
      heading={strengths.heading}
      lead={strengths.lead}
    />

    <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        strengths.items.map((item) => (
          <article class="surface surface-hover p-7" data-reveal>
            <div class="grid h-12 w-12 place-items-center rounded-2xl bg-gradient-to-br from-violet/25 to-lavender/25 text-sm font-bold text-lavender">
              {item.marker}
            </div>
            <h3 class="mt-5 text-xl font-semibold">{item.title}</h3>
            <p class="mt-3 text-muted">{item.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
