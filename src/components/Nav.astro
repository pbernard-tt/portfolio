---
import { site, nav } from "../data/site";
---

<header class="sticky top-0 z-50">
  <div class="border-b border-line bg-bg/70 backdrop-blur-lg">
    <nav
      class="container-x flex items-center justify-between py-4"
      aria-label="Primary"
    >
      <a href="#top" class="flex items-center gap-3 font-semibold">
        <span
          class="grid h-9 w-9 place-items-center rounded-xl bg-gradient-to-br from-blue to-green text-sm font-bold text-[#04101f]"
        >
          {site.initials}
        </span>
        <span>{site.name}</span>
      </a>

      <div class="hidden items-center gap-1 md:flex">
        {
          nav.map((item) => (
            <a
              href={item.href}
              class="rounded-full px-4 py-2 text-sm text-muted transition-colors hover:bg-card hover:text-text"
            >
              {item.label}
            </a>
          ))
        }
      </div>

      <a href="#contact" class="btn btn-secondary hidden text-sm sm:inline-flex">
        Get in touch
      </a>
    </nav>
  </div>
</header>
