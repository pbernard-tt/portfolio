---
import { stack } from "../data/site";
---

<section id="stack" class="section">
  <div class="container-x">
    <div
      class="surface relative overflow-hidden p-8 sm:p-12"
      data-reveal
    >
      <div
        class="pointer-events-none absolute -right-10 -top-10 -z-0 h-64 w-64 rounded-full bg-lavender/10 blur-3xl"
        aria-hidden="true"
      >
      </div>

      <div class="grid grid-cols-1 gap-10 lg:grid-cols-[0.8fr_1.2fr]">
        <div>
          <p class="label">{stack.label}</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">
            {stack.heading}
          </h2>
          <p class="mt-5 text-muted">{stack.lead}</p>
        </div>

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          {
            stack.groups.map((group) => (
              <div>
                <h3 class="text-xs font-bold uppercase tracking-widest text-muted">
                  {group.name}
                </h3>
                <div class="mt-3 flex flex-wrap gap-2">
                  {group.items.map((item) => (
                    <span class="chip">{item}</span>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
