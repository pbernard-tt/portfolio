---
import { Image } from "astro:assets";
import SectionHead from "./SectionHead.astro";
import { featuredWork, type LogoKey } from "../data/site";
import konvelo from "../assets/logos/konvelo.png";
import vulkan from "../assets/logos/vulkan.png";
import concorde from "../assets/logos/concorde.png";
import appdoctor from "../assets/logos/appdoctor.png";

const logos: Record<LogoKey, ImageMetadata> = {
  konvelo,
  vulkan,
  concorde,
  appdoctor,
};
---

<section id="work" class="section bg-bg-soft/40">
  <div class="container-x">
    <SectionHead
      label={featuredWork.label}
      heading={featuredWork.heading}
      lead={featuredWork.lead}
    />

    <div class="mt-12 grid grid-cols-1 gap-6 lg:grid-cols-2">
      {
        featuredWork.projects.map((item) => (
          <article
            class:list={[
              "surface surface-hover flex h-full flex-col p-7 sm:p-8",
              item.title === "Konvelo" ? "lg:col-span-2" : "",
            ]}
            data-reveal
          >
            <div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:justify-between">
              <div class="flex items-center gap-4">
                <div
                  class:list={[
                    "grid h-14 w-14 shrink-0 place-items-center overflow-hidden rounded-2xl border border-line",
                    item.logoFill ? "bg-card p-0" : "bg-white/95 p-2.5",
                  ]}
                >
                  <Image
                    src={logos[item.logo]}
                    alt={`${item.title} logo`}
                    width={56}
                    height={56}
                    class:list={[
                      "h-full w-full",
                      item.logoFill ? "object-cover" : "object-contain",
                    ]}
                  />
                </div>
                <div>
                  <p class="label">{item.type}</p>
                  <h3 class="mt-1 text-2xl font-bold">{item.title}</h3>
                </div>
              </div>
              <span class="chip w-fit shrink-0">{item.status}</span>
            </div>

            <p class="mt-5 text-muted">{item.description}</p>

            <div class="mt-6 grid gap-5 border-t border-line pt-6 lg:grid-cols-[0.85fr_1.15fr]">
              <div>
                <h4 class="text-xs font-bold uppercase tracking-widest text-muted">
                  My role
                </h4>
                <p class="mt-2 text-sm font-semibold text-text">{item.role}</p>
              </div>
              <div>
                <h4 class="text-xs font-bold uppercase tracking-widest text-muted">
                  What I built / contributed
                </h4>
                <ul class="mt-2 grid gap-2 text-sm text-muted sm:grid-cols-2">
                  {
                    item.built.map((contribution) => (
                      <li class="flex gap-2">
                        <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-violet" />
                        <span>{contribution}</span>
                      </li>
                    ))
                  }
                </ul>
              </div>
            </div>

            <div class="mt-6 grid gap-5 border-t border-line pt-6 lg:grid-cols-2">
              <div>
                <h4 class="text-xs font-bold uppercase tracking-widest text-muted">
                  Stack
                </h4>
                <div class="mt-3 flex flex-wrap gap-2">
                  {item.stack.map((tech) => <span class="chip">{tech}</span>)}
                </div>
              </div>
              <div>
                <h4 class="text-xs font-bold uppercase tracking-widest text-muted">
                  Tags
                </h4>
                <div class="mt-3 flex flex-wrap gap-2">
                  {item.tags.map((tag) => <span class="chip">{tag}</span>)}
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
