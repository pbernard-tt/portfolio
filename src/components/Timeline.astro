---
import SectionHead from "./SectionHead.astro";
import { roles } from "../data/site";
---

<section id="experience" class="section bg-bg-soft/40">
  <div class="container-x">
    <SectionHead label={roles.label} heading={roles.heading} lead={roles.lead} />

    <ol class="mt-12 grid grid-cols-1 gap-5 lg:grid-cols-3">
      {
        roles.items.map((item) => (
          <li class="surface surface-hover p-6" data-reveal>
            <span class="inline-flex h-fit w-fit items-center rounded-full border border-line bg-card px-3 py-1 text-sm font-semibold text-violet">
              {item.type}
            </span>
            <h3 class="mt-5 text-xl font-semibold">{item.title}</h3>
            <p class="mt-3 text-sm text-muted">{item.body}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
